{
  "name": "Overworld Site Distribution — distributional metrics for site placement across seeded worlds",
  "description": "Measures how sites are distributed across the overworld patch: total placed, populated cells, empty cells, max density, enterable ratio, spacing rejections. Warning-oriented: no hard thresholds, just observation until baseline is characterized.",
  "endpoint": "narrate",
  "method": "POST",
  "extract": "site_placement_log",
  "request_lifecycle": "session_per_run",
  "request_template": {
    "action": "look around",
    "WORLD_PROMPT": "i am standing in an open field",
    "WORLD_SEED": "$SEED"
  },
  "metrics": [
    "total_sites_placed",
    "total_cells_evaluated",
    "populated_cells_count",
    "pct_populated_cells",
    "empty_cells_count",
    "max_sites_per_cell",
    "mean_sites_per_populated_cell",
    "enterable_ratio",
    "spacing_rejections"
  ],
  "percentile_metrics": [
    "total_sites_placed",
    "populated_cells_count",
    "pct_populated_cells",
    "max_sites_per_cell",
    "enterable_ratio",
    "spacing_rejections"
  ],
  "warnings": {
    "total_sites_placed": {
      "min": 1,
      "hard_max": 200
    },
    "spacing_rejections": {
      "hard_max": 100
    },
    "enterable_ratio": {
      "min": 0.3,
      "max": 0.9
    },
    "pct_populated_cells": {
      "min": 5,
      "max": 95
    }
  },
  "expected_runtime_ms_per_run": 5000
}