{
  "name": "worldgen-sites-refined",
  "description": "Iterative refinement probe for overworld site distribution. Uses /narrate endpoint to trigger worldgen with a fresh session per run. Warning-oriented thresholds. Designed for staged runs: 1 to 5 to 10 to 50.",
  "endpoint": "narrate",
  "method": "POST",
  "extract": "site_placement_log",
  "request_lifecycle": "session_per_run",
  "inter_run_delay_ms": 3000,
  "expected_runtime_ms_per_run": 60000,
  "request_template": {
    "action": "i am standing in an open field under a clear sky",
    "WORLD_SEED": "$SEED"
  },
  "metrics": [
    "total_sites_placed",
    "total_cells_evaluated",
    "populated_cells_count",
    "pct_populated_cells",
    "empty_cells_count",
    "max_sites_per_cell",
    "mean_sites_per_populated_cell",
    "enterable_ratio",
    "spacing_rejections",
    "edge_concentration_pct"
  ],
  "percentile_metrics": [
    "total_sites_placed",
    "pct_populated_cells",
    "empty_cells_count",
    "enterable_ratio",
    "spacing_rejections",
    "edge_concentration_pct"
  ],
  "edge_topology": {
    "radius": 3,
    "anchor_path": "state.world.position"
  },
  "warnings": {
    "total_sites_placed": {
      "min": 1,
      "max": 100
    },
    "pct_populated_cells": {
      "min": 1,
      "max": 100
    },
    "empty_cells_count": {
      "min": 0,
      "max": 100
    },
    "enterable_ratio": {
      "min": 0.1,
      "max": 1
    },
    "spacing_rejections": {
      "max": 50
    },
    "edge_concentration_pct": {
      "min": 0,
      "max": 100
    }
  }
}
